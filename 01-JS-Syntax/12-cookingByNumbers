function cooking (startNumber, operation1, operation2, operation3, operation4, operation5 ) {

    let number = Number(startNumber)
    let operations = [operation1, operation2, operation3, operation4, operation5]

    for (let index = 0; index < operations.length; index++) {
        let currentOperation = operations[index]

        switch (currentOperation) {
            case `chop`:
                number = number / 2                               
                break;
            case `dice`:
                number = Math.sqrt(number)                             
                break;
            case `spice`:
                number = number + 1                               
                break;
            case `bake`:
                number = number * 3                               
                break;
            case `fillet`:
                number = number * 0.8                               
                break;
        }
        
        console.log(number)
    }
}
cooking(9, `spice`, `spice`, `bake`, `fillet`, `chop`)